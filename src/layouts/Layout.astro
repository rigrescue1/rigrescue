---
import '../styles/global.css';
---

<!doctype html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>RigRescue - Remote Computer Repair & Tech Support</title>
    <meta name="description" content="Expert remote computer repair, tech assistance, website creation, and consulting in Deltona, FL.">

    <!-- Favicon -->
    <link rel="icon" type="image/png" href="/favicon.png" sizes="32x32">
    <link rel="icon" type="image/png" href="/favicon.png" sizes="16x16">
    <link rel="apple-touch-icon" sizes="180x180" href="/favicon.png">
    <link rel="shortcut icon" href="/favicon.png">
</head>
<body class="bg-gray-950 text-white font-sans">
    <!-- Header -->
    <header class="border-b border-gray-800 bg-gray-900 sticky top-0 z-50">
        <div class="max-w-6xl mx-auto px-6 py-4 flex items-center justify-between">
            <a href="/" class="flex items-center gap-3">
                <img src="/logo.png" alt="RigRescue Logo" class="h-10 w-auto">
                <span class="text-2xl font-bold hidden sm:inline">RigRescue</span>
            </a>
            <nav class="hidden md:flex items-center gap-8 text-sm uppercase tracking-wider">
                <a href="/" class="hover:text-blue-400 transition">Home</a>
                <a href="/services" class="hover:text-blue-400 transition">Services</a>
                <a href="/websites" class="hover:text-blue-400 transition">Websites</a>
                <a href="/about" class="hover:text-blue-400 transition">About</a>
                <a href="/contact" class="hover:text-blue-400 transition">Contact</a>
            </nav>
            <a href="/contact"
               class="bg-blue-600 hover:bg-blue-500 px-6 py-2.5 rounded-lg text-sm font-medium transition">
                Book Session
            </a>
        </div>
    </header>

    <!-- Page Content Slot -->
    <slot />

    <!-- Footer -->
    <footer class="bg-gray-900 border-t border-gray-800 py-12">
        <div class="max-w-6xl mx-auto px-6 text-center text-gray-400 text-sm">
            <p>&copy; 2026 RigRescue.net • Remote Tech Support & Consulting</p>
            <p class="mt-3 flex flex-wrap justify-center gap-x-6 gap-y-1 text-xs">
                <a href="/privacy" class="hover:text-white transition">Privacy Policy</a>
                <a href="/terms" class="hover:text-white transition">Terms of Service</a>
                <a href="mailto:support@rigrescue.net" class="hover:text-white">support@rigrescue.net</a>
            </p>
        </div>
    </footer>
</body>
</html>
