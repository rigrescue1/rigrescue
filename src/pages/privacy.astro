---
import Layout from '../layouts/Layout.astro';
---

<Layout>
    <div class="bg-gray-950 py-20">
        <div class="max-w-3xl mx-auto px-6 prose prose-invert">
            <h1 class="text-4xl font-bold mb-8">Privacy Policy</h1>
            <p class="text-sm text-gray-400">Last updated: July 2026</p>

            <h2 class="text-2xl font-semibold mt-10">1. Information We Collect</h2>
            <p>We collect only the information necessary to provide remote and local tech support:</p>
            <ul>
                <li>Contact details (name, email, phone)</li>
                <li>Device details needed for diagnosis and repair</li>
                <li>Payment information (processed securely by Stripe)</li>
            </ul>

            <h2 class="text-2xl font-semibold mt-10">2. How We Use Your Information</h2>
            <p>We use your information solely to deliver the requested services, communicate about repairs, and process payments.</p>

            <h2 class="text-2xl font-semibold mt-10">3. Data Sharing</h2>
            <p>We do not sell your data. We may share limited information with payment processors (Stripe) or remote tools (AnyDesk/TeamViewer) only as needed to complete the service.</p>

            <h2 class="text-2xl font-semibold mt-10">4. Your Rights</h2>
            <p>You may request access, correction, or deletion of your data by contacting us.</p>

            <h2 class="text-2xl font-semibold mt-10">Contact Us</h2>
            <p>Email: support@rigrescue.net</p>
        </div>
    </div>
</Layout>
