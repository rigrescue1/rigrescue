---
import Layout from '../layouts/Layout.astro';
---

<Layout>
    <div class="bg-gray-950 py-20">
        <div class="max-w-2xl mx-auto px-6">
            <h1 class="text-5xl font-bold text-center mb-8">Get In Touch</h1>
            <p class="text-xl text-gray-400 text-center mb-12">
                Ready for help? Start with a $50 diagnostic (credited toward repair).
                I'll respond quickly.
            </p>

            <div class="bg-gray-900/70 border border-gray-700 rounded-3xl p-12 space-y-10">
                <div>
                    <p class="text-blue-400 font-medium mb-1">Email (Fastest Response)</p>
                    <a href="mailto:anthonyjames@rigrescue.net"
                       class="text-2xl hover:text-blue-400 transition break-all">
                        anthonyjames@rigrescue.net
                    </a>
                </div>

                <div>
                    <p class="text-blue-400 font-medium mb-1">Phone / Text</p>
                    <p class="text-2xl text-gray-300">Coming soon — or email to schedule a call</p>
                </div>

                <div class="pt-8 border-t border-gray-700">
                    <p class="text-gray-400 mb-6">Prefer to schedule directly?</p>
                    <div class="bg-gray-800 border border-dashed border-gray-600 rounded-2xl p-12 text-center">
                        <p class="text-gray-400">Calendly Booking Widget Goes Here</p>
                        <p class="text-sm mt-3">(Easy to add once you create a free Calendly account)</p>
                    </div>
                </div>
            </div>

            <p class="text-center text-gray-500 mt-12 text-sm">
                Deltona, Florida • Serving remote clients nationwide
            </p>
        </div>
    </div>
</Layout>
