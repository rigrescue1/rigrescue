---
import Layout from '../layouts/Layout.astro';
---

<Layout>
    <div class="bg-gray-950 py-20">
        <div class="max-w-2xl mx-auto px-6">
            <h1 class="text-5xl font-bold text-center mb-8">Get In Touch</h1>
            <p class="text-xl text-gray-400 text-center mb-12">
                Ready for help? Start with a $50 diagnostic (credited toward repair).<br>
                I'll respond quickly.
            </p>

            <div class="bg-gray-900/70 border border-gray-700 rounded-3xl p-12 space-y-10">
                <div>
                    <p class="text-blue-400 font-medium mb-1">Email (Fastest Response)</p>
                    <a href="mailto:anthonyjames@rigrescue.net"
                       class="text-2xl hover:text-blue-400 transition break-all">
                        anthonyjames@rigrescue.net
                    </a>
                </div>

                <div>
                    <p class="text-blue-400 font-medium mb-1">Phone / Text</p>
                    <p class="text-2xl text-gray-300">Email to schedule a call</p>
                </div>

                <div class="pt-8 border-t border-gray-700">
                    <p class="text-gray-400 mb-6">Book a 30 Min Remote Consultation</p>
                    <!-- Calendly Embed -->
                    <div class="calendly-inline-widget"
                         data-url="https://calendly.com/anthonyjames-rigrescue/30min"
                         style="min-width:320px;height:700px;"></div>
                    <script type="text/javascript" src="https://assets.calendly.com/assets/external/widget.js" async></script>
                </div>
            </div>

            <div class="text-center text-gray-500 mt-12 text-sm">
                Deltona, Florida • Serving remote clients nationwide
            </div>

            <!-- Legal Links -->
            <div class="text-center text-gray-500 mt-8 text-xs">
                <a href="/privacy" class="hover:text-gray-300 mx-2">Privacy Policy</a> |
                <a href="/terms" class="hover:text-gray-300 mx-2">Terms of Service</a>
            </div>
        </div>
    </div>
</Layout>
