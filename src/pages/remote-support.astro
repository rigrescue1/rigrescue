---
import Layout from '../layouts/Layout.astro';
---

<Layout>
    <div class="bg-gray-950 py-20">
        <div class="max-w-6xl mx-auto px-6">
            <h1 class="text-5xl font-bold text-center mb-8">Secure Remote Support</h1>
            <p class="text-2xl text-blue-400 text-center mb-16 max-w-3xl mx-auto">
                Fast, encrypted remote help using our private connection. No third-party tracking.
            </p>

            <div class="flex flex-col items-center gap-8 mb-20">
                <a href="https://rustdesk.com"
                   target="_blank"
                   class="inline-flex items-center gap-4 bg-blue-600 hover:bg-blue-500 px-12 py-6 rounded-3xl text-2xl font-medium transition-all">
                    <span class="text-4xl">⬇️</span>
                    Download Secure Client (Free)
                </a>
                <p class="text-gray-400">Windows • Mac • Linux</p>
            </div>

            <div class="max-w-2xl mx-auto text-lg leading-relaxed text-gray-200 space-y-8">
                <h2 class="text-3xl font-semibold text-center mb-8">How It Works</h2>
                <ol class="space-y-8 list-decimal list-inside">
                    <li>Download and run the client above (no installation required for quick sessions).</li>
                    <li>Note the 9-digit ID shown on the screen.</li>
                    <li>During your booked session, share the ID with me.</li>
                    <li>I connect securely and we fix the issue together ($50 diagnostic credited toward repair).</li>
                </ol>
            </div>

            <div class="text-center mt-20">
                <a href="/contact"
                   class="inline-block bg-blue-600 hover:bg-blue-500 px-12 py-5 rounded-2xl text-xl font-medium transition">
                    Book Your Session
                </a>
            </div>
        </div>
    </div>
</Layout>
