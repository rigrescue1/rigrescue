---
import Layout from '../layouts/Layout.astro';
---

<Layout>
    <div class="bg-gray-950 py-20">
        <div class="max-w-6xl mx-auto px-6">
            <h1 class="text-5xl font-bold text-center mb-8">Secure Remote Support</h1>
            <p class="text-2xl text-blue-400 text-center mb-16">2-minute setup. Encrypted & private.</p>

            <div class="flex flex-col items-center gap-8 mb-16">
                <a href="https://rustdesk.com" target="_blank" class="inline-flex items-center gap-4 bg-blue-600 hover:bg-blue-500 px-12 py-6 rounded-3xl text-2xl font-medium transition-all">
                    ⬇️ Download RustDesk (Free)
                </a>
                <p class="text-sm text-gray-400">Windows • Mac • Linux</p>
            </div>

            <div class="max-w-3xl mx-auto text-lg space-y-12">
                <div>
                    <h3 class="font-semibold text-xl mb-4">After Downloading & Running:</h3>
                    <ol class="list-decimal pl-6 space-y-6">
                        <li>Open <strong>Settings → Network</strong> (three dots menu top right)</li>
                        <li>Enter these two fields exactly:
                            <div class="mt-3 bg-gray-900 p-4 rounded-2xl font-mono text-sm">
                                ID Server: [remote.rigrescue.net]<br>
                                Key: sCLvNTBqSevmOhEdr2sqDwSHSKqyxYDdVPEdDFf92x0=
                            </div>
                        </li>
                        <li>Click Apply → Restart the app if asked.</li>
                        <li>Send me the 9-digit ID shown on the main screen.</li>
                    </ol>
                </div>
            </div>

            <div class="text-center mt-20">
                <a href="/contact" class="inline-block bg-blue-600 hover:bg-blue-500 px-12 py-5 rounded-2xl text-xl font-medium transition">
                    Book a Session
                </a>
            </div>
        </div>
    </div>
</Layout>
