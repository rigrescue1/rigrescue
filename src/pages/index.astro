---
import Layout from '../layouts/Layout.astro';
---

<Layout>
    <!-- Hero Section -->
    <section class="bg-gradient-to-br from-gray-900 to-black py-24">
        <div class="max-w-6xl mx-auto px-6 text-center">
            <h1 class="text-5xl md:text-6xl font-bold mb-6 leading-tight">
                Remote Computer Repair & Website Services<br>
                <span class="text-blue-500">Deltona & Nationwide</span>
            </h1>
            <p class="text-xl text-gray-300 max-w-2xl mx-auto mb-10">
                Expert remote computer repair, virus removal, custom PC builds,
                and professional website creation & maintenance.
            </p>

            <div class="flex flex-col sm:flex-row gap-4 justify-center">
                <a href="/contact"
                   class="bg-blue-600 hover:bg-blue-500 px-10 py-4 rounded-xl text-lg font-medium inline-block transition">
                    Book a $50 Diagnostic
                </a>
                <a href="/services"
                   class="border border-gray-400 hover:bg-white hover:text-black px-10 py-4 rounded-xl text-lg font-medium inline-block transition">
                    View All Services
                </a>
            </div>
        </div>
    </section>

    <!-- Trust Bar -->
    <div class="bg-gray-900 py-4 border-b border-gray-800">
        <div class="max-w-6xl mx-auto px-6 text-center text-sm text-gray-400">
            Trusted Remote Computer Repair • Website Creation • No Travel Fees • Deltona, FL
        </div>
    </div>

    <!-- Services Teaser -->
    <section class="py-20 bg-gray-950">
        <div class="max-w-6xl mx-auto px-6">
            <h2 class="text-4xl font-bold text-center mb-12">Our Services</h2>
            <div class="grid md:grid-cols-3 gap-8">
                <div class="bg-gray-900 p-8 rounded-2xl">
                    <h3 class="text-2xl font-semibold mb-4">Remote Computer Repair</h3>
                    <p class="text-gray-400">Virus removal, performance tuning, Windows/Linux support, and troubleshooting.</p>
                </div>
                <div class="bg-gray-900 p-8 rounded-2xl">
                    <h3 class="text-2xl font-semibold mb-4">Local PC Builds & Consulting</h3>
                    <p class="text-gray-400">Custom gaming rigs, homelab setups, and in-person support in Deltona area.</p>
                </div>
                <div class="bg-gray-900 p-8 rounded-2xl">
                    <h3 class="text-2xl font-semibold mb-4">Website Creation & Maintenance</h3>
                    <p class="text-gray-400">Modern, fast websites for small businesses with SEO and easy management.</p>
                </div>
            </div>
        </div>
    </section>
</Layout>
