---
import Layout from '../layouts/Layout.astro';
---

<Layout>
    <!-- Hero Section -->
    <section class="bg-gradient-to-br from-gray-900 to-black py-24">
        <div class="max-w-6xl mx-auto px-6 text-center">
            <h1 class="text-5xl md:text-6xl font-bold mb-6 leading-tight">
                Remote Computer Repair<br>
                <span class="text-blue-500">When You Need It Most</span>
            </h1>
            <p class="text-xl text-gray-300 max-w-2xl mx-auto mb-10">
                Expert remote tech support and consulting. Fast diagnostics, repairs, and guidance for Windows, Linux, and everything in between.
            </p>

            <div class="flex flex-col sm:flex-row gap-4 justify-center">
                <a href="/contact"
                   class="bg-blue-600 hover:bg-blue-500 px-10 py-4 rounded-xl text-lg font-medium inline-block transition">
                    Book a Remote Session
                </a>
                <a href="/services"
                   class="border border-gray-400 hover:bg-white hover:text-black px-10 py-4 rounded-xl text-lg font-medium inline-block transition">
                    See Our Services
                </a>
            </div>
        </div>
    </section>

    <!-- Trust Bar -->
    <div class="bg-gray-900 py-4 border-b border-gray-800">
        <div class="max-w-6xl mx-auto px-6 text-center text-sm text-gray-400">
            Trusted remote support • No travel fees • Secure connections via our secure encrypted remote connection
        </div>
    </div>

    <!-- Services Teaser -->
    <section class="py-20 bg-gray-950">
        <div class="max-w-6xl mx-auto px-6">
            <h2 class="text-4xl font-bold text-center mb-12">How We Can Help</h2>
            <div class="grid md:grid-cols-3 gap-8">
                <div class="bg-gray-900 p-8 rounded-2xl">
                    <h3 class="text-2xl font-semibold mb-4">Remote Repair</h3>
                    <p class="text-gray-400">Virus removal, performance tuning, software issues, hardware troubleshooting — all done remotely.</p>
                </div>
                <div class="bg-gray-900 p-8 rounded-2xl">
                    <h3 class="text-2xl font-semibold mb-4">Tech Consulting</h3>
                    <p class="text-gray-400">Homelab setup, Linux/Windows optimization, gaming rigs, network advice, and more.</p>
                </div>
                <div class="bg-gray-900 p-8 rounded-2xl">
                    <h3 class="text-2xl font-semibold mb-4">Ongoing Support</h3>
                    <p class="text-gray-400">Monthly retainers and quick help for families and small businesses.</p>
                </div>
            </div>
        </div>
    </section>
</Layout>
