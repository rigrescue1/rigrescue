---
import Layout from '../layouts/Layout.astro';
---

<Layout>
    <div class="bg-gray-950 py-20">
        <div class="max-w-6xl mx-auto px-6">
            <h1 class="text-5xl font-bold text-center mb-6">Website Creation & Maintenance</h1>
            <p class="text-xl text-gray-400 text-center max-w-2xl mx-auto mb-16">
                Professional, fast-loading websites for small businesses and individuals.<br>
                Built with modern tools — just like RigRescue.net.
            </p>

            <div class="grid md:grid-cols-2 gap-10">
                <div class="bg-gray-900 rounded-3xl p-10">
                    <div class="text-4xl mb-6">🌐</div>
                    <h3 class="text-3xl font-semibold mb-4">New Website Creation</h3>
                    <ul class="space-y-3 text-gray-300 mb-8">
                        <li>• Modern, mobile-friendly designs</li>
                        <li>• Fast loading (Astro / static sites)</li>
                        <li>• Contact forms & booking systems</li>
                        <li>• SEO optimized from day one</li>
                    </ul>
                    <p class="text-blue-400 font-medium">Starting at custom quote</p>
                </div>

                <div class="bg-gray-900 rounded-3xl p-10">
                    <div class="text-4xl mb-6">🔧</div>
                    <h3 class="text-3xl font-semibold mb-4">Website Maintenance & Updates</h3>
                    <ul class="space-y-3 text-gray-300 mb-8">
                        <li>• Regular updates & security patches</li>
                        <li>• Content updates</li>
                        <li>• Performance optimization</li>
                        <li>• Hosting & domain management</li>
                    </ul>
                    <p class="text-blue-400 font-medium">Monthly plans available</p>
                </div>
            </div>

            <div class="text-center mt-16">
                <a href="/contact"
                   class="inline-block bg-blue-600 hover:bg-blue-500 px-12 py-5 rounded-2xl text-xl font-medium transition">
                    Get a Website Quote
                </a>
            </div>
        </div>
    </div>
</Layout>
