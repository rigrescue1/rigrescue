---
import Layout from '../layouts/Layout.astro';
---

<Layout>
    <div class="bg-gray-950 py-20">
        <div class="max-w-5xl mx-auto px-6">
            <h1 class="text-5xl font-bold text-center mb-8">About RigRescue</h1>
            <p class="text-2xl text-blue-400 text-center mb-16 max-w-3xl mx-auto">
                Nearly 20 years of technical expertise — delivered with honesty and care.
            </p>

            <div class="max-w-3xl mx-auto text-lg leading-relaxed text-gray-200 space-y-8">
                <p>
                    Hi, I'm Anthony — founder of RigRescue. With nearly 20 years of hands-on technical experience
                    and a proven track record running high-performing retail operations, I understand both complex systems
                    and what real customers need.
                </p>

                <p>
                    I started RigRescue to provide straightforward, reliable tech support — remote or local —
                    without the confusion, upsells, or frustration common in the industry.
                </p>

                <p>
                    Based in Deltona, Florida, I serve clients remotely across the country and provide in-person
                    help in the Deltona / Deland / Orange City area.
                </p>
            </div>

            <!-- Why Choose Us -->
            <div class="mt-20">
                <h2 class="text-3xl font-semibold text-center mb-10">Why Work With RigRescue?</h2>
                <div class="grid md:grid-cols-3 gap-8">
                    <div class="text-center">
                        <div class="text-5xl mb-4">✅</div>
                        <h3 class="font-semibold mb-2">Transparent Pricing</h3>
                        <p class="text-gray-400">$50 diagnostic — always credited. Clear quotes before any work begins.</p>
                    </div>
                    <div class="text-center">
                        <div class="text-5xl mb-4">🔒</div>
                        <h3 class="font-semibold mb-2">Secure & Reliable</h3>
                        <p class="text-gray-400">Professional tools and practices. No shady remote access.</p>
                    </div>
                    <div class="text-center">
                        <div class="text-5xl mb-4">🧠</div>
                        <h3 class="font-semibold mb-2">Real Expertise</h3>
                        <p class="text-gray-400">Deep knowledge across Windows, Linux, homelabs, builds, and troubleshooting.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</Layout>
