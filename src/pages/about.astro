---
import Layout from '../layouts/Layout.astro';
---

<Layout>
    <div class="bg-gray-950 py-20">
        <div class="max-w-5xl mx-auto px-6">
            <h1 class="text-5xl font-bold text-center mb-8">About RigRescue – Computer Repair in Deltona</h1>
            <p class="text-2xl text-blue-400 text-center mb-16 max-w-3xl mx-auto">
                Nearly 20 years of technical expertise — delivered with honesty and care.
            </p>

            <div class="max-w-3xl mx-auto text-lg leading-relaxed text-gray-200 space-y-8">
                <p>
                    Hi, I'm Anthony — founder of RigRescue. With nearly 20 years of hands-on experience in computer repair,
                    systems troubleshooting, and running high-performing operations, I created RigRescue to provide
                    straightforward, reliable tech support without the upsells or confusion.
                </p>

                <p>
                    I specialize in remote computer repair, virus removal, custom PC builds, homelab setups,
                    and local in-person service in the Deltona, Deland, and Orange City area.
                </p>

                <p>
                    Whether you're dealing with a malware infection, need a new gaming rig built, or want help setting up
                    a home server — my focus is clear communication and getting your technology working reliably.
                </p>
            </div>

            <!-- Why Choose Us -->
            <div class="mt-20">
                <h2 class="text-3xl font-semibold text-center mb-10">Why Choose RigRescue for Computer Repair?</h2>
                <div class="grid md:grid-cols-3 gap-8">
                    <div class="text-center">
                        <div class="text-5xl mb-4">✅</div>
                        <h3 class="font-semibold mb-2">Transparent Pricing</h3>
                        <p class="text-gray-400">$50 diagnostic — always credited. Clear quotes before any work begins.</p>
                    </div>
                    <div class="text-center">
                        <div class="text-5xl mb-4">🔒</div>
                        <h3 class="font-semibold mb-2">Secure & Reliable</h3>
                        <p class="text-gray-400">Professional tools (AnyDesk/TeamViewer) and no shady practices.</p>
                    </div>
                    <div class="text-center">
                        <div class="text-5xl mb-4">🧠</div>
                        <h3 class="font-semibold mb-2">Real Expertise</h3>
                        <p class="text-gray-400">Deep knowledge of Windows, Linux, gaming PCs, homelabs, and troubleshooting.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</Layout>
